{
    "name" : "fastbolt/command-scheduler",
    "type" : "library",
    "description" : "",
    "keywords" : [
        "fastbolt",
        "command",
        "scheduler",
        "symfony"
    ],
    "homepage" : "https://github.com/fastbolt/command-scheduler",
    "license" : "MIT",
    "authors" : [
        {
            "name" : "Daniel Hirtzbruch",
            "email" : "dhh@fastbolt.com",
            "homepage" : "https://github.com/dhirtzbruch",
            "role" : "Developer"
        }
    ],
    "require" : {
        "php" : ">=8.2",
        "doctrine/doctrine-bundle" : "^2.6",
        "doctrine/orm" : "^2.12|^3.2",
        "doctrine/persistence" : "^2.4|^3.0",
        "dragonmantank/cron-expression" : "^3.6",
        "symfony/config" : "^6.4",
        "symfony/console" : "^6.4",
        "symfony/framework-bundle" : "^6.4",
        "symfony/lock" : "^6.4"
    },
    "require-dev" : {
        "fig-r/psr2r-sniffer" : "^1.3",
        "phpstan/phpstan" : "^1.4",
        "phpunit/phpunit" : "^9.5",
        "psalm/plugin-phpunit" : "^0.19",
        "psalm/plugin-symfony" : "^v5.3",
        "slevomat/coding-standard" : "^7.0",
        "spryker/code-sniffer" : "^0.17.4",
        "squizlabs/php_codesniffer" : "^3.6",
        "symfony/maker-bundle" : "^1.62",
        "vimeo/psalm" : "^6.16",
        "weirdan/doctrine-psalm-plugin" : "^v2.10"
    },
    "autoload" : {
        "psr-4" : {
            "Fastbolt\\CommandScheduler\\" : "src/"
        }
    },
    "autoload-dev" : {
        "psr-4" : {
            "Fastbolt\\CommandScheduler\\Tests\\" : "tests/"
        }
    },
    "scripts" : {
        "test" : "phpunit",
        "check-style" : "phpcs src tests",
        "fix-style" : "phpcbf src tests"
    },
    "extra" : {
        "branch-alias" : {
            "dev-main" : "1.0-dev"
        }
    },
    "config" : {
        "optimize-autoloader" : true,
        "sort-packages" : true,
        "preferred-install" : "dist",
        "allow-plugins" : {
            "dealerdirect/phpcodesniffer-composer-installer" : true
        }
    },
    "prefer-stable" : true
}
