{% trans_default_domain 'command-scheduler' %}

{% import '@CommandScheduler/helpers/macros.html.twig' as macros %}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8"/>
    <title>Fastbolt Command Scheduler {% block command_scheduler_title %}{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('bundles/commandscheduler/app.css') }}">
    {% endblock %}
</head>
<body id="command-scheduler">
<div>
    <header>
        {% block command_scheduler_header %}
        <nav class="cs-navbar">
            <div class="cs-navbar-container">
                <span class="cs-navbar-brand">Command Scheduler</span>
                <ul class="cs-navbar-links">
                    <li class="{% if commandSchedulerActiveView == 'schedules-list' %}active{% endif %}">
                        <a href="{{ path('command_scheduler_schedules_list') }}">
                            {{ macros.icon_schedules() }} {{ 'command-scheduler.menu.schedules'|trans }}
                        </a>
                    </li>
                    <li class="{% if commandSchedulerActiveView == 'logs-list' %}active{% endif %}">
                        <a href="{{ path('command_scheduler_logs_list') }}">
                            {{ macros.icon_logs() }} {{ 'command-scheduler.menu.logs'|trans }}
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
        {% endblock %}
    </header>
    <main>
        {% block command_scheduler_content %}{% endblock %}
    </main>
</div>
{% block command_scheduler_javascripts %}{% endblock %}
</body>
</html>
